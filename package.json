{
  "name": "codebar",
  "version": "1.0.0",
  "description": "API de códigos de barras para el mercado mexicano — EAN-13, UPC, QR, Code128",
  "author": "AurumCapitalHolding",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx lib/db/migrate.ts",
    "db:seed": "tsx -e \"import('./lib/db/seed.ts').then(m => m.seed()).then(() => process.exit(0))\""
  },
  "dependencies": {
    "html5-qrcode": "^2.3.8",
    "@zxing/library": "^0.23.0",
    "axios": "^1.17.0",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.9",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-zxing": "^3.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
